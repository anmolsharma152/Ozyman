# =============================================================================
# Ozyman — environment template
# Copy to .env.local for Next.js local dev. Never commit real values.
# Edge / InsForge secrets: npx @insforge/cli secrets add KEY VALUE
# Design: docs/design-ozyman-personal-operator-os.md (Appendix A)
# Setup:  docs/setup.md
# =============================================================================

# --- InsForge (public — safe for browser bundle) ---
# API base for project ozyman (ap-southeast)
NEXT_PUBLIC_INSFORGE_URL=https://sik8rdbp.ap-southeast.insforge.app
# Anon / publishable key from InsForge dashboard or project link
NEXT_PUBLIC_INSFORGE_ANON_KEY=
# Public app origin (OAuth redirects, email deep links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- InsForge admin (server / edge only — never NEXT_PUBLIC_*) ---
# Used by cron edge functions with createAdminClient
INSFORGE_URL=https://sik8rdbp.ap-southeast.insforge.app
INSFORGE_API_KEY=

# --- OpenRouter / AI (server / edge only) ---
# Prefer: npx @insforge/cli ai setup  (stores gateway key in InsForge)
# Local override if calling OpenRouter directly from Next:
OPENROUTER_API_KEY=
# Default chat model (override without code change)
OPENROUTER_CHAT_MODEL=openai/gpt-4.1-mini
# Embeddings — later phase
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Composio (server / edge only — never NEXT_PUBLIC_*) ---
COMPOSIO_API_KEY=
# Best-effort seed for profiles.composio_entity_id (CLI consumer entity id).
# May not see the same ACTIVE connections as the CLI; re-link in app if smoke fails.
COMPOSIO_DEFAULT_ENTITY_ID=

# --- Morning brief / cron (edge + schedule Authorization header) ---
# Schedule: Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=
# Primary operator auth.users UUID (n=1 personal OS)
MORNING_BRIEF_USER_ID=

# --- Digest email (Resend-first on free InsForge plan) ---
# resend | insforge — default resend (InsForge custom email needs paid plan)
DIGEST_EMAIL_PROVIDER=resend
# Required when DIGEST_EMAIL_PROVIDER=resend
RESEND_API_KEY=
# Verified Resend sender (domain or single sender). Design alias: DIGEST_FROM_EMAIL
DIGEST_FROM_EMAIL=
# Optional alias used by some Resend setups — prefer DIGEST_FROM_EMAIL in code
# RESEND_FROM_EMAIL=

# --- Tool-run safety (recommended) ---
# Encrypt tool_runs.args_execute at rest
TOOL_ARGS_ENCRYPTION_KEY=
